generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id           String    @id @default(cuid())
  name         String
  phone        String?
  email        String?   @unique
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@index([name])
  @@index([email])
  @@index([phone])
}

model Booking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId   String
  sitterId   String?
  operatorId String // 🔹 who owns this booking

  clientLinkToken   String        @unique @default(cuid())
  notes             String?
  startTime         DateTime
  endTime           DateTime
  status            BookingStatus @default(REQUESTED)
  clientTotalCents  Int
  platformFeeCents  Int
  sitterPayoutCents Int
  priceConfirmedAt  DateTime?
  canceledAt        DateTime?
  completedAt       DateTime?
  confirmedAt       DateTime?

  serviceSummary String?

  // 🔹 optional service reference
  serviceId String?
  service   Service? @relation("BookingService", fields: [serviceId], references: [id])

  client Client @relation(fields: [clientId], references: [id])

  // 🔹 OPERATOR + SITTER relations
  operator User  @relation("BookingOperator", fields: [operatorId], references: [id])
  sitter   User? @relation("BookingSitter", fields: [sitterId], references: [id])

  // 🔹 CHILD VISITS (the missing side)
  visits Visit[] // <— THIS is what Prisma wants

  history   BookingHistory[]
  lineItems BookingLineItem[]

  @@index([startTime])
  @@index([status, startTime])
  @@index([clientId, startTime])
  @@index([sitterId, startTime])
  @@index([operatorId, startTime])
}

model BookingLineItem {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  bookingId       String
  label           String
  quantity        Int      @default(1)
  unitPriceCents  Int
  totalPriceCents Int
  booking         Booking  @relation(fields: [bookingId], references: [id])
}

model Visit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  // 🔹 We keep operator + sitter here for fast queries and future scaling
  operatorId String
  operator   User   @relation("VisitOperator", fields: [operatorId], references: [id])

  sitterId String?
  sitter   User?   @relation("VisitSitter", fields: [sitterId], references: [id])

  // 🔹 Date + time window
  // date: stored at midnight for the calendar "day"
  date      DateTime
  startTime DateTime
  endTime   DateTime

  status VisitStatus @default(CONFIRMED)

  @@index([bookingId])
  @@index([operatorId, date])
  @@index([sitterId, date])
  @@index([startTime, endTime])
}

model BookingHistory {
  id              String         @id @default(cuid())
  createdAt       DateTime       @default(now())
  bookingId       String
  changedByUserId String?
  fromStatus      BookingStatus?
  toStatus        BookingStatus?
  fromSitterId    String?
  toSitterId      String?
  note            String?
  booking         Booking        @relation(fields: [bookingId], references: [id])
  changedBy       User?          @relation("HistoryChangedBy", fields: [changedByUserId], references: [id])
  fromSitter      User?          @relation("HistoryFromSitter", fields: [fromSitterId], references: [id])
  toSitter        User?          @relation("HistoryToSitter", fields: [toSitterId], references: [id])

  @@index([bookingId, createdAt])
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  role               Role
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  emailVerified      DateTime?
  hashedPassword     String?
  mustChangePassword Boolean   @default(false)

  accounts Account[]
  sessions Session[]

  // 🔹 Bookings where this user is the SITTER
  sitterBookings Booking[] @relation("BookingSitter")

  // 🔹 Bookings where this user is the OPERATOR (Bridget)
  operatorBookings Booking[] @relation("BookingOperator")

  // 🔹 Visits where this user is the OPERATOR
  visitsAsOperator Visit[] @relation("VisitOperator")

  // 🔹 Visits where this user is the SITTER
  visitsAsSitter Visit[] @relation("VisitSitter")

  // History relations unchanged
  historyEntries    BookingHistory[] @relation("HistoryChangedBy")
  historyFromSitter BookingHistory[] @relation("HistoryFromSitter")
  historyToSitter   BookingHistory[] @relation("HistoryToSitter")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Service {
  id              String  @id @default(cuid())
  name            String // e.g. "Dog Overnight (in your home)"
  code            String  @unique // e.g. "DOG_OVERNIGHT_HOME"
  species         String // "DOG", "CAT", "MIXED"
  category        String // "OVERNIGHT", "DROP_IN", "WALK", "EXTRA"
  durationMinutes Int? // null for overnights, 15/30/60 for drop-ins/walks
  basePriceCents  Int // price per visit/night in cents
  notes           String? // any extra explanation
  isActive        Boolean @default(true)

  bookings Booking[] @relation("BookingService")
}

enum Role {
  OPERATOR
  SITTER
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELED
}

enum ServiceType {
  OVERNIGHT
  WALK
  DROP_IN
}

enum VisitStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}
